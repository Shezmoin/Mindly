# Environment Variables for Mindly
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Stripe Payment Configuration
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product/Price IDs
# Create a product in Stripe Dashboard for "Premium Subscription"
# Set price to £9.99/month (GBP)
STRIPE_PREMIUM_PRICE_ID=price_your_price_id_here

# Database (PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/mindly

# Email Configuration (for production)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
